# =============================================================================
# Tibia Guild Platform — Environment Variables
# Copy to .env in each service repo or use this file with docker-compose
# =============================================================================

# --- Database ---
POSTGRES_USER=tibia
POSTGRES_PASSWORD=tibia_secret
POSTGRES_DB=tibia_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tibia:tibia_secret@localhost:5432/tibia_platform

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BOT_API_KEY=change-me-bot-api-key

# --- Discord OAuth (Dashboard) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/callback/discord

# --- Discord Bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID_BOT=

# --- Web Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret

# --- TibiaData API ---
TIBIA_DATA_API_URL=https://api.tibiadata.com/v4

# --- Worker ---
WORKER_CONCURRENCY=5
